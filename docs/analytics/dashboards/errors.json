{
  "title": "Brain — Errors",
  "uid": "brain-errors",
  "tags": ["brain", "errors"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Error rate by op",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (op) (rate(brain_request_total{status=\"error\"}[1m]))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Timeouts/sec by op",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (op) (rate(brain_request_total{status=\"timeout\"}[1m]))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error ratio (errors / all requests)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(brain_request_total{status=\"error\"}[1m])) / clamp_min(sum(rate(brain_request_total[1m])), 0.001)",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Worker errors/sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (worker) (rate(brain_worker_errors_total[1m]))",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ]
    }
  ]
}
