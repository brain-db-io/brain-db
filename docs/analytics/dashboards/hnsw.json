{
  "title": "Brain — HNSW",
  "uid": "brain-hnsw",
  "tags": ["brain", "hnsw"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Node count (deferred)",
      "description": "Awaiting `brain_hnsw_node_count` (deferred: phase-12/hnsw-sampling).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "brain_hnsw_node_count", "legendFormat": "{{shard}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Tombstone ratio (deferred)",
      "description": "Alert threshold per spec §14/05: > 0.3 sustained.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "brain_hnsw_tombstone_ratio", "legendFormat": "{{shard}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Rebuild in progress (deferred)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "brain_hnsw_rebuild_in_progress", "legendFormat": "{{shard}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Search visits (deferred)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (shard, le) (rate(brain_hnsw_search_visits_bucket[5m])))",
          "legendFormat": "p99 {{shard}}",
          "refId": "A"
        }
      ]
    }
  ]
}
