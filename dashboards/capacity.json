{
  "title": "Brain — Capacity",
  "uid": "brain-capacity",
  "tags": ["brain", "capacity"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Resident memory (RSS)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "process_memory_resident_bytes", "legendFormat": "rss", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Open file descriptors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "process_open_fds", "legendFormat": "fds", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU seconds (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total[1m])", "legendFormat": "cpu", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory growth forecast (predict_linear, 6h)",
      "description": "Linear projection 6h ahead. Useful for capacity planning.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "predict_linear(process_memory_resident_bytes[1h], 6 * 3600)",
          "legendFormat": "rss @ +6h",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
