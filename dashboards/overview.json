{
  "title": "Brain — Overview",
  "uid": "brain-overview",
  "tags": ["brain", "overview"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "annotations": { "list": [] },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Up",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        { "expr": "brain_up", "legendFormat": "up", "refId": "A" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Shards",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        { "expr": "brain_shards_total", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active connections",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        { "expr": "brain_connections_active", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Build",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "brain_build_info", "legendFormat": "{{version}} ({{git_commit}})", "refId": "A" }
      ],
      "options": { "textMode": "name" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests/sec by op",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (op) (rate(brain_request_total[1m]))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error rate (% of requests)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (op) (rate(brain_request_total{status=\"error\"}[1m])) / sum by (op) (rate(brain_request_total[1m])) * 100",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latency p99 by op",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (op, le) (rate(brain_request_duration_ms_bucket[1m])))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Worker cycles/sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (worker) (rate(brain_worker_cycles_total[5m]))",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ]
    }
  ]
}
