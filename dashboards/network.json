{
  "title": "Brain — Network",
  "uid": "brain-network",
  "tags": ["brain", "network"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "brain_connections_active", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Accepts/sec",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        { "expr": "rate(brain_connections_total[1m])", "legendFormat": "accepts/s", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests in flight by op",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "brain_request_active", "legendFormat": "{{op}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Frame send rate (deferred)",
      "description": "Awaiting `brain_frame_send_total` (deferred: phase-12/connection-extended).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (op) (rate(brain_frame_send_total[1m]))",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ]
    }
  ]
}
