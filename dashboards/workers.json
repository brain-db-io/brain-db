{
  "title": "Brain — Workers",
  "uid": "brain-workers",
  "tags": ["brain", "workers"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Last run age (seconds)",
      "description": "Per-worker time since last cycle. Yellow > 5m, red > 1h.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "time() - brain_worker_last_run_unixtime",
          "legendFormat": "shard {{shard}} / {{worker}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 3600 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cycles/sec",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (worker) (rate(brain_worker_cycles_total[1m]))",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Items processed/sec",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum by (worker) (rate(brain_worker_processed_total[1m]))",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Errors/sec",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "sum by (worker) (rate(brain_worker_errors_total[1m]))",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ]
    }
  ]
}
