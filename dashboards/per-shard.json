{
  "title": "Brain — Per-shard",
  "uid": "brain-per-shard",
  "tags": ["brain", "shard"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "shard",
        "type": "query",
        "query": "label_values(brain_worker_cycles_total, shard)",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "refresh": 1,
        "current": { "text": "0", "value": "0" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Worker cycles (shard $shard)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (worker) (rate(brain_worker_cycles_total{shard=\"$shard\"}[1m]))",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Worker errors (shard $shard)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (worker) (rate(brain_worker_errors_total{shard=\"$shard\"}[1m]))",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "table",
      "title": "Worker last run (shard $shard)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "time() - brain_worker_last_run_unixtime{shard=\"$shard\"}",
          "legendFormat": "{{worker}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Items processed/sec (shard $shard)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (worker) (rate(brain_worker_processed_total{shard=\"$shard\"}[1m]))",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ]
    }
  ]
}
