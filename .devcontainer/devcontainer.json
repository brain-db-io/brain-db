{
  "name": "brain-dev",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/brain,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/brain",

  // Persistent named volumes for cargo registry and target dir so a fresh
  // container start doesn't re-download dependencies. See README.md
  // "Development environment" for the rationale.
  // Only mount the cargo *cache* subdirectories — not the whole CARGO_HOME.
  // CARGO_HOME/bin contains image-baked tools (just, cargo-fuzz, cargo-audit);
  // a volume on the parent would shadow them.
  "mounts": [
    "source=brain-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=brain-cargo-git,target=/usr/local/cargo/git,type=volume",
    "source=brain-target-cache,target=/workspaces/brain/target,type=volume",
    // Per-shard data files (arena.bin, metadata.redb, llm_cache.redb, …)
    // need a filesystem that honors POSIX flock. OrbStack's `fakeowner`
    // bind mount over macOS host does not — redb's `Database::create`
    // sometimes hits a spurious `WouldBlock` on `try_lock()` and returns
    // `DatabaseAlreadyOpen`, even though no other process holds the
    // lock. Putting data/ on a named volume (Linux ext4) sidesteps this
    // entirely. Production on bare Linux is unaffected.
    "source=brain-data,target=/workspaces/brain/data,type=volume",
    // BGE-small embed + BERT NER model artifacts (~550 MiB total).
    // Persisted across container rebuilds so post-create.sh's
    // bootstrap-model.sh invocation is a no-op on every iteration
    // after the first. Without this volume the models redownload
    // on every `devcontainer up` after a rebuild.
    "source=brain-models,target=/root/.local/share/brain/models,type=volume"
  ],

  "remoteEnv": {
    "RUST_BACKTRACE": "1",
    "CARGO_TERM_COLOR": "always",
    // Cap parallel compile jobs to avoid the OOM-killer (signal 9) on the
    // linker when many crates link concurrently in an 8–12 GB Docker
    // Desktop VM. 2 is conservative; bump if your container has 16+ GB.
    "CARGO_BUILD_JOBS": "2"

    // target-cpu / fullfp16 handling lives in .cargo/config.toml as
    // per-target rustflags so it scopes to aarch64-unknown-linux-gnu only.
    // Don't add a RUSTFLAGS entry here — env vars OVERRIDE the per-target
    // config and we lose the macOS-host vs Linux-container distinction.
  },

  // Phase 9 unlock: io_uring (Glommio executor) needs both the memlock
  // rlimit raised and seccomp permissions for io_uring_setup/enter/register.
  // Spec §01/05 §1.3.
  "runArgs": [
    "--ulimit", "memlock=-1",
    "--security-opt", "seccomp=unconfined"
  ],

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // Editor integration. devcontainer.json is the lingua franca across
  // VS Code, Cursor, JetBrains, and GitHub Codespaces; these settings
  // are read by VS Code / Cursor and silently ignored elsewhere.
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.cargo.allTargets": true,
        "files.watcherExclude": {
          "**/target/**": true
        }
      }
    }
  },

  // Phase 9 unlocks (memlock + seccomp) are baked in above; aarch64 target
  // tuning is in .cargo/config.toml. VS Code / Cursor "Reopen in Container"
  // picks both up automatically. Bare `devcontainer` CLI:
  //   devcontainer up --workspace-folder .
  //   devcontainer exec --workspace-folder . cargo test --workspace --tests --lib
  // (Install via `npm install -g @devcontainers/cli` if missing.)

  "remoteUser": "root"
}
